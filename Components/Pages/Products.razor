@page "/products"
@rendermode InteractiveServer
@inject IProductService ProductService
@inject ICategoryService CategoryService
@inject ICartService CartService
@inject ICurrentUserService CurrentUser
@inject NavigationManager Nav

<PageTitle>Каталог — BookHaven</PageTitle>

<h1 class="mb-4"><i class="bi bi-journal-bookmark"></i> Книжная полка</h1>

<div class="row">
    <aside class="col-md-3">
        <div class="bh-sidebar p-3 sticky-top" style="top: 80px;">
            <h5 class="text-bh mb-3"><i class="bi bi-bookshelf"></i> Категории</h5>
            <div class="list-group list-group-flush">
                <button class="list-group-item list-group-item-action @(SelectedShelfId == 0 ? "active-bh" : "")" @onclick="@(() => PickShelf(0))">Все книги</button>
                @if (shelves != null)
                {
                    foreach (var c in shelves)
                    {
                        <button class="list-group-item list-group-item-action @(SelectedShelfId == c.Id ? "active-bh" : "")" @onclick="@(() => PickShelf(c.Id))">@c.Name</button>
                    }
                }
            </div>
        </div>
    </aside>
    <section class="col-md-9">
        @if (books == null) { <p><em>Загрузка...</em></p> }
        else if (!books.Any()) { <div class="alert alert-info">Книги не найдены.</div> }
        else
        {
            <div class="row g-4">
                @foreach (var p in books)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="card bh-book-card h-100">
                            @if (!string.IsNullOrEmpty(p.ImageUrl))
                            { <img src="@p.ImageUrl" class="card-img-top" style="height: 280px; object-fit: cover;" /> }
                            <div class="card-body d-flex flex-column">
                                <h6 class="fw-bold">@p.Name</h6>
                                <small class="text-muted mb-2"><i class="bi bi-bookmark"></i> @p.Category?.Name</small>
                                <p class="small flex-grow-1">@p.Description</p>
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <strong class="text-bh fs-5">@p.Price.ToString("N0") ₽</strong>
                                    <small class="text-muted">@p.Stock шт.</small>
                                </div>
                                <div class="d-grid gap-2">
                                    <a class="btn btn-outline-bh btn-sm" href="@($"/products/{p.Id}")">Подробнее</a>
                                    <button class="btn btn-bh btn-sm" @onclick="() => OrderBook(p.Id)" disabled="@(p.Stock == 0)"><i class="bi bi-bag-plus"></i> Купить</button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </section>
</div>

@code {
    private IEnumerable<Models.Product>? books;
    private IEnumerable<Models.Category>? shelves;
    private int SelectedShelfId { get; set; } = 0;

    protected override async Task OnInitializedAsync()
    {
        shelves = await CategoryService.GetAllAsync();
        await LoadBooks();
    }

    private async Task PickShelf(int catId) { SelectedShelfId = catId; await LoadBooks(); }

    private async Task LoadBooks()
    {
        books = SelectedShelfId == 0
            ? await ProductService.GetAllAsync()
            : await ProductService.GetByCategoryAsync(SelectedShelfId);
    }

    private async Task OrderBook(int id)
    {
        var c = await CurrentUser.GetOrCreateGuestReaderAsync();
        await CartService.AddToCartAsync(c.Id, id);
        Nav.NavigateTo("/cart");
    }
}